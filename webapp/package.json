{
  "name": "vite-8-sample-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "build": "tsgo && vite build",
    "check": "tsgo && oxlint . && oxfmt --config ./.oxfmt.json --check",
    "check:fix": "tsgo && oxlint . --fix && oxfmt --config ./.oxfmt.json --write",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "oxlint .",
    "fmt": "oxfmt --config ./.oxfmt.json --check",
    "fmt:fix": "oxfmt --config ./.oxfmt.json --write",
    "generate": "orval --config orval.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.91.2",
    "@tanstack/react-router": "^1.167.5",
    "@tanstack/router-plugin": "^1.166.14",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "msw": "^2.12.13",
    "orval": "^8.5.3",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.16.0",
    "playwright": "^1.58.2",
    "vite": "^8.0.0",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@10.32.1",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
